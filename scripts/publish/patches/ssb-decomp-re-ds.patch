diff --git a/src/mv/mvopening/mvopeningroom.c b/src/mv/mvopening/mvopeningroom.c
index 7b2154ed..740e8109 100644
--- a/src/mv/mvopening/mvopeningroom.c
+++ b/src/mv/mvopening/mvopeningroom.c
@@ -1,11 +1,741 @@
 #include <ft/fighter.h>
+#if !defined(SSB64_TARGET_NDS)
 #include <gr/ground.h>
+#endif
 #include <mv/movie.h>
 #include <sc/scene.h>
 #include <sys/video.h>
 #include <sys/rdp.h>
 #include <reloc_data.h>
 
+#if defined(SSB64_TARGET_NDS)
+
+#include <nds/nds_startup.h>
+#include <sys/controller.h>
+#include <sys/obj.h>
+#include <sys/objanim.h>
+#include <sys/objdisplay.h>
+#include <sys/objhelper.h>
+#include <sys/objman.h>
+#include <sys/taskman.h>
+#include <sys/utils.h>
+
+/* NDS entry slice.
+ *
+ * Keep the original scene entry, task setup, actor, camera, and first update
+ * on the executable path. The rest of this file still needs the Opening Room
+ * relocation assets, fighter manager, effects, audio, and display-list
+ * backend, so the N64 body remains below for builds with those dependencies.
+ * This is a port boundary, not replacement movie/gameplay logic. */
+
+s32 sMVOpeningRoomTotalTimeTics;
+GObj *sMVOpeningRoomCameraGObj;
+s32 sMVOpeningRoomPulledFighterKind;
+s32 sMVOpeningRoomDroppedFighterKind;
+s32 sMVOpeningRoomUnused0x80134D54;
+GObj *sMVOpeningRoomPencilsGObj;
+s32 sMVOpeningRoomOverlayAlpha;
+GObj *sMVOpeningRoomOverlayGObj;
+GObj *sMVOpeningRoomMainCameraGObj;
+GObj *sMVOpeningRoomFighterCameraGObj;
+GObj *sMVOpeningRoomLogoCameraGObj;
+GObj *sMVOpeningRoomLogoGObj;
+GObj *sMVOpeningRoomBossShadowGObj;
+GObj *sMVOpeningRoomSpotlightGObj;
+
+u32 dMVOpeningRoomFileIDs[/* */] =
+{
+	(u32)&llMVCommonFileID,
+	(u32)&llMVOpeningRoomTransitionFileID,
+	(u32)&llMVOpeningRoomScene1FileID,
+	(u32)&llMVOpeningRoomScene2FileID,
+	(u32)&llMVOpeningRoomScene3FileID,
+	(u32)&llMVOpeningRoomScene4FileID,
+	(u32)&llMVOpeningRunCrashFileID,
+	(u32)&llMVOpeningRoomWallpaperFileID
+};
+
+LBFileNode sMVOpeningRoomStatusBuffer[100];
+LBFileNode sMVOpeningRoomForceStatusBuffer[7];
+void *sMVOpeningRoomFiles[ARRAY_COUNT(dMVOpeningRoomFileIDs)];
+
+void mvOpeningRoomMakePencils(void);
+void mvOpeningRoomInitScene1Cameras(GObj *gobj);
+void mvOpeningRoomMakeScene1Cameras(void);
+void mvOpeningRoomEjectCameraGObjs(void);
+void mvOpeningRoomInitScene2Cameras(GObj *gobj);
+void mvOpeningRoomMakeScene2Cameras(void);
+void mvOpeningRoomMakeCloseUpOverlayCamera(void);
+void mvOpeningRoomMakeWallpaperCamera(void);
+void mvOpeningRoomMakeLogoCamera(void);
+void mvOpeningRoomMakeLogoWallpaper(void);
+void mvOpeningRoomMakeLogo(void);
+void mvOpeningRoomMakeBossShadow(void);
+void mvOpeningRoomCloseUpOverlayProcDisplay(GObj *gobj);
+void mvOpeningRoomMakeCloseUpOverlay(void);
+void mvOpeningRoomSetSpotlightPosition(GObj *gobj, s32 fkind);
+void mvOpeningRoomMakeSpotlight(void);
+void lbCommonDrawSprite(GObj *camera_gobj);
+
+s32 mvOpeningRoomGetDroppedFighterKind(void)
+{
+	s32 fkinds[] =
+	{
+		nFTKindMario,
+		nFTKindFox,
+		nFTKindDonkey,
+		nFTKindSamus,
+		nFTKindLink,
+		nFTKindYoshi,
+		nFTKindKirby,
+		nFTKindPikachu
+	};
+	s32 fkind;
+
+	do
+	{
+		fkind = fkinds[syUtilsRandTimeUCharRange(ARRAY_COUNT(fkinds))];
+	}
+	while (fkind == sMVOpeningRoomPulledFighterKind);
+
+	return fkind;
+}
+
+s32 mvOpeningRoomGetPulledFighterKind(void)
+{
+	s32 fkinds[] =
+	{
+		nFTKindMario,
+		nFTKindFox,
+		nFTKindDonkey,
+		nFTKindSamus,
+		nFTKindLink,
+		nFTKindYoshi,
+		nFTKindKirby,
+		nFTKindPikachu
+	};
+
+	return fkinds[syUtilsRandTimeUCharRange(ARRAY_COUNT(fkinds))];
+}
+
+void mvOpeningRoomInitVars(void)
+{
+	sMVOpeningRoomTotalTimeTics = 0;
+	sMVOpeningRoomPencilsGObj = NULL;
+	sMVOpeningRoomPulledFighterKind = mvOpeningRoomGetPulledFighterKind();
+	sMVOpeningRoomDroppedFighterKind = mvOpeningRoomGetDroppedFighterKind();
+	gNdsOpeningRoomPulledFighterKind = (u32)sMVOpeningRoomPulledFighterKind;
+	gNdsOpeningRoomDroppedFighterKind = (u32)sMVOpeningRoomDroppedFighterKind;
+}
+
+void mvOpeningRoomFuncRun(GObj *gobj)
+{
+	(void)gobj;
+	sMVOpeningRoomTotalTimeTics++;
+
+	if (sMVOpeningRoomTotalTimeTics >= 10)
+	{
+		gNdsOpeningRoomControllerCheckCount++;
+
+		if (sMVOpeningRoomUnused0x80134D54 != 0)
+		{
+			sMVOpeningRoomUnused0x80134D54--;
+		}
+		if
+		(
+			(scSubsysControllerGetPlayerStickInRangeLR(-15, 15) != FALSE) &&
+			(scSubsysControllerGetPlayerStickInRangeUD(-15, 15) != FALSE)
+		)
+		{
+			sMVOpeningRoomUnused0x80134D54 = 0;
+		}
+		if (scSubsysControllerGetPlayerTapButtons(A_BUTTON | B_BUTTON | START_BUTTON) != FALSE)
+		{
+			gSCManagerSceneData.scene_prev = gSCManagerSceneData.scene_curr;
+			gSCManagerSceneData.scene_curr = nSCKindTitle;
+			gNdsOpeningRoomSkipToTitleCount++;
+			syTaskmanSetLoadScene();
+		}
+		if (sMVOpeningRoomTotalTimeTics == 280)
+		{
+			/*
+			 * Preserve the first tick-280 object boundary without importing
+			 * the fighter/effect/render stack yet. The original tick order is
+			 * fighter creation, pencils, then logo/overlay/boss-shadow
+			 * ejections. Logo, overlay, and boss-shadow ejections are now real
+			 * because their setup objects are in this slice.
+			 */
+			gNdsOpeningRoomFighterDeferredKind =
+				(u32)sMVOpeningRoomPulledFighterKind;
+			gNdsOpeningRoomFighterDeferredResult =
+				NDS_OPENING_ROOM_FIGHTER_DEFER_PASS;
+			gNdsOpeningRoomFirstEventDeferredMask =
+				NDS_OPENING_ROOM_TICK280_DEFER_MASK;
+
+			ndsOpeningRoomCapturePencilsCountsBefore();
+			mvOpeningRoomMakePencils();
+			ndsOpeningRoomCapturePencilsCreation();
+			gNdsOpeningRoomFirstEventRunResult =
+				NDS_OPENING_ROOM_FIRST_EVENT_RUN_PASS;
+
+			if (sMVOpeningRoomLogoGObj != NULL)
+			{
+				gNdsOpeningRoomLogoEjectBeforeGObjCount =
+					(u32)gcGetGObjsActiveNum();
+				gcEjectGObj(sMVOpeningRoomLogoGObj);
+				gNdsOpeningRoomLogoEjectAfterGObjCount =
+					(u32)gcGetGObjsActiveNum();
+				ndsOpeningRoomRecordLogoEject(sMVOpeningRoomLogoGObj);
+			}
+			if (sMVOpeningRoomOverlayGObj != NULL)
+			{
+				gNdsOpeningRoomOverlayEjectBeforeGObjCount =
+					(u32)gcGetGObjsActiveNum();
+				gcEjectGObj(sMVOpeningRoomOverlayGObj);
+				gNdsOpeningRoomOverlayEjectAfterGObjCount =
+					(u32)gcGetGObjsActiveNum();
+				ndsOpeningRoomRecordOverlayEject(sMVOpeningRoomOverlayGObj);
+			}
+			if (sMVOpeningRoomBossShadowGObj != NULL)
+			{
+				gNdsOpeningRoomBossShadowEjectBeforeGObjCount =
+					(u32)gcGetGObjsActiveNum();
+				gcEjectGObj(sMVOpeningRoomBossShadowGObj);
+				gNdsOpeningRoomBossShadowEjectAfterGObjCount =
+					(u32)gcGetGObjsActiveNum();
+				ndsOpeningRoomRecordBossShadowEject(sMVOpeningRoomBossShadowGObj);
+			}
+		}
+		if (sMVOpeningRoomTotalTimeTics == 380)
+		{
+			gNdsOpeningRoomTick380DeferredMask =
+				NDS_OPENING_ROOM_TICK380_DEFER_MASK;
+			gNdsOpeningRoomTick380DeferredResult =
+				NDS_OPENING_ROOM_TICK380_DEFER_PASS;
+		}
+		if (sMVOpeningRoomTotalTimeTics == 450)
+		{
+			/*
+			 * The original event creates the close-up overlay and ejects the
+			 * sunlight GObj. Sunlight belongs to the unimported room object
+			 * slice, so only that ejection remains deferred here.
+			 */
+			ndsOpeningRoomCaptureCloseUpOverlayCountsBefore();
+			mvOpeningRoomMakeCloseUpOverlay();
+			ndsOpeningRoomCaptureCloseUpOverlayCreation(sMVOpeningRoomOverlayGObj);
+			gNdsOpeningRoomTick450DeferredMask =
+				NDS_OPENING_ROOM_TICK450_DEFER_MASK;
+			gNdsOpeningRoomTick450RunResult =
+				NDS_OPENING_ROOM_TICK450_RUN_PASS;
+		}
+		if (sMVOpeningRoomTotalTimeTics == 500)
+		{
+			/*
+			 * The original event first moves the pulled fighter's display
+			 * link, then creates the spotlight. The fighter is still guarded,
+			 * so keep that first branch explicit and run only the bounded
+			 * original spotlight object path.
+			 */
+			gNdsOpeningRoomTick500DeferredMask =
+				NDS_OPENING_ROOM_TICK500_DEFER_MASK;
+			ndsOpeningRoomCaptureSpotlightCountsBefore();
+			mvOpeningRoomMakeSpotlight();
+			ndsOpeningRoomCaptureSpotlightCreation(sMVOpeningRoomSpotlightGObj);
+			gNdsOpeningRoomTick500RunResult =
+				NDS_OPENING_ROOM_TICK500_RUN_PASS;
+		}
+		if (sMVOpeningRoomTotalTimeTics == 560)
+		{
+			/*
+			 * The original tick-560 event swaps Scene 1 cameras for Scene 2
+			 * cameras, then updates the Boss fighter status. Boss fighter
+			 * creation is still outside this slice, so the fighter-status
+			 * branch remains a named defer while the camera transition is real.
+			 */
+			ndsOpeningRoomCaptureScene2CameraEjectBefore();
+			mvOpeningRoomEjectCameraGObjs();
+			ndsOpeningRoomRecordScene2CameraEject();
+			ndsOpeningRoomCaptureScene2CameraCountsBefore();
+			mvOpeningRoomMakeScene2Cameras();
+			ndsOpeningRoomCaptureScene2CameraCreation();
+			gNdsOpeningRoomTick560DeferredMask =
+				NDS_OPENING_ROOM_TICK560_DEFER_MASK;
+			gNdsOpeningRoomTick560RunResult =
+				NDS_OPENING_ROOM_TICK560_RUN_PASS;
+		}
+	}
+}
+
+void mvOpeningRoomFuncStart(void)
+{
+	LBRelocSetup rl_setup;
+
+	gNdsOpeningRoomFuncStartResult = NDS_OPENING_ROOM_FUNC_START_PASS;
+
+	rl_setup.table_addr = (uintptr_t)&lLBRelocTableAddr;
+	rl_setup.table_files_num = (u32)&llRelocFileCount;
+	rl_setup.file_heap = NULL;
+	rl_setup.file_heap_size = 0;
+	rl_setup.status_buffer = sMVOpeningRoomStatusBuffer;
+	rl_setup.status_buffer_size = ARRAY_COUNT(sMVOpeningRoomStatusBuffer);
+	rl_setup.force_status_buffer = sMVOpeningRoomForceStatusBuffer;
+	rl_setup.force_status_buffer_size = ARRAY_COUNT(sMVOpeningRoomForceStatusBuffer);
+
+	lbRelocInitSetup(&rl_setup);
+	lbRelocLoadFilesListed(dMVOpeningRoomFileIDs, sMVOpeningRoomFiles);
+
+	gcMakeGObjSPAfter(0, mvOpeningRoomFuncRun, 0, GOBJ_PRIORITY_DEFAULT);
+	sMVOpeningRoomCameraGObj = gcMakeDefaultCameraGObj(
+		0,
+		GOBJ_PRIORITY_DEFAULT,
+		100,
+		COBJ_FLAG_FILLCOLOR | COBJ_FLAG_ZBUFFER,
+		GPACK_RGBA8888(0x00, 0x00, 0x00, 0xFF));
+
+	mvOpeningRoomInitVars();
+	mvOpeningRoomMakeScene1Cameras();
+	mvOpeningRoomMakeCloseUpOverlayCamera();
+	mvOpeningRoomMakeWallpaperCamera();
+	mvOpeningRoomMakeLogoCamera();
+	mvOpeningRoomMakeLogoWallpaper();
+	mvOpeningRoomMakeLogo();
+	mvOpeningRoomMakeBossShadow();
+}
+
+void mvOpeningRoomCommonProcUpdate(GObj *gobj)
+{
+	if (sMVOpeningRoomTotalTimeTics >= 560)
+	{
+		gcPlayAnimAll(gobj);
+	}
+}
+
+void mvOpeningRoomMakePencils(void)
+{
+	GObj *gobj;
+
+	sMVOpeningRoomPencilsGObj = gobj = gcMakeGObjSPAfter(0, NULL, 17, GOBJ_PRIORITY_DEFAULT);
+	gcSetupCommonDObjs(gobj, lbRelocGetFileData(DObjDesc*, sMVOpeningRoomFiles[0], &llMVCommonRoomPencilsDObjDesc), NULL);
+	gcAddGObjDisplay(gobj, gcDrawDObjTreeForGObj, 6, GOBJ_PRIORITY_DEFAULT, ~0);
+	gcAddAnimJointAll(gobj, lbRelocGetFileData(AObjEvent32**, sMVOpeningRoomFiles[0], &llMVCommonRoomPencilsAnimJoint), 0.0F);
+	gcAddGObjProcess(gobj, mvOpeningRoomCommonProcUpdate, nGCProcessKindFunc, 1);
+	gcPlayAnimAll(gobj);
+}
+
+void mvOpeningRoomInitScene1Cameras(GObj *gobj)
+{
+	CObj *cobj = CObjGetStruct(gobj);
+
+	syRdpSetViewport(&cobj->viewport, 10.0F, 10.0F, 310.0F, 230.0F);
+
+	cobj->projection.persp.near = 80.0F;
+	cobj->projection.persp.far = 15000.0F;
+
+	gcAddCObjCamAnimJoint(cobj, lbRelocGetFileData(AObjEvent32*, sMVOpeningRoomFiles[2], &llMVOpeningRoomScene1CamAnimJoint), 0.0F);
+	gcAddGObjProcess(gobj, gcPlayCamAnim, nGCProcessKindFunc, 1);
+
+	cobj->flags |= COBJ_FLAG_DLBUFFERS;
+}
+
+void mvOpeningRoomMakeScene1Cameras(void)
+{
+	GObj *gobj;
+
+	ndsOpeningRoomCaptureScene1CameraCountsBefore();
+	sMVOpeningRoomMainCameraGObj = gobj = gcMakeCameraGObj
+	(
+		nGCCommonKindSceneCamera,
+		NULL,
+		16,
+		GOBJ_PRIORITY_DEFAULT,
+		func_80017EC0,
+		80,
+		COBJ_MASK_DLLINK(6),
+		~0,
+		FALSE,
+		nGCProcessKindFunc,
+		NULL,
+		1,
+		FALSE
+	);
+	gcAddXObjForCamera(CObjGetStruct(gobj), nGCMatrixKindPerspFastF, 0);
+	gcAddXObjForCamera(CObjGetStruct(gobj), 14, 0);
+	mvOpeningRoomInitScene1Cameras(gobj);
+
+	sMVOpeningRoomFighterCameraGObj = gobj = gcMakeCameraGObj
+	(
+		nGCCommonKindSceneCamera,
+		NULL,
+		16,
+		GOBJ_PRIORITY_DEFAULT,
+		func_80017EC0,
+		40,
+		COBJ_MASK_DLLINK(27) | COBJ_MASK_DLLINK(9),
+		~0,
+		TRUE,
+		nGCProcessKindFunc,
+		NULL,
+		1,
+		FALSE
+	);
+	mvOpeningRoomInitScene1Cameras(gobj);
+	ndsOpeningRoomCaptureScene1CameraCreation();
+}
+
+void mvOpeningRoomEjectCameraGObjs(void)
+{
+	gcEjectGObj(sMVOpeningRoomMainCameraGObj);
+	gcEjectGObj(sMVOpeningRoomFighterCameraGObj);
+}
+
