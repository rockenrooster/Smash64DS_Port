+		func_80017EC0,
+		80,
+		COBJ_MASK_DLLINK(6),
+		~0,
+		FALSE,
+		nGCProcessKindFunc,
+		NULL,
+		1,
+		FALSE
+	);
+	gcAddXObjForCamera(CObjGetStruct(gobj), nGCMatrixKindPerspFastF, 0);
